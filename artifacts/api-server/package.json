{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:aws-sdk --external:mock-aws-s3 --external:nock --loader:.html=text",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:migrate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "3.525.0",
    "@types/dotenv": "^8.2.3",
    "bcrypt": "5.1.1",
    "bullmq": "5.0.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.29.0",
    "express": "5.0.0-beta.3",
    "express-rate-limit": "7.2.0",
    "helmet": "7.1.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "music-metadata": "7.13.4",
    "pg": "8.12.0",
    "rate-limit-redis": "^5.0.0",
    "tsx": "4.7.2",
    "youtube-dl-exec": "2.5.8",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/compression": "1.7.5",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-rate-limit": "6.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.10",
    "@types/multer": "1.4.11",
    "@types/node": "20.12.7",
    "@types/pg": "8.11.4",
    "@typescript-eslint/eslint-plugin": "7.6.0",
    "@typescript-eslint/parser": "7.6.0",
    "drizzle-kit": "0.20.14",
    "esbuild": "0.20.2",
    "eslint": "8.57.0",
    "typescript": "5.7.2"
  }
}