{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:aws-sdk --external:mock-aws-s3 --external:nock --loader:.html=text --external:canvas --external:sharp --external:node-vibrant",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-content": "tsx src/db/seed-content.ts",
    "db:seed-images": "tsx src/db/seed-images.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1059.0",
    "@aws-sdk/s3-request-presigner": "3.1059.0",
    "@types/nodemailer": "8.0.0",
    "@types/pdfkit": "0.17.6",
    "@types/sharp": "0.32.0",
    "bcryptjs": "3.0.3",
    "blurhash": "2.0.5",
    "bullmq": "5.0.0",
    "canvas": "3.2.3",
    "compression": "1.7.4",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "exceljs": "^4.4.0",
    "express": "5.0.0",
    "express-rate-limit": "7.4.0",
    "helmet": "8.0.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "music-metadata": "11.12.3",
    "node-cron": "^4.6.0",
    "node-vibrant": "3.2.1-alpha.1",
    "nodemailer": "8.0.10",
    "openai": "6.41.0",
    "pdfkit": "0.18.0",
    "pg": "8.13.0",
    "pino": "9.5.0",
    "rate-limit-redis": "5.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "0.34.5",
    "tsx": "4.7.2",
    "uuid": "14.0.0",
