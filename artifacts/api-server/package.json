    "@types/express": "4.17.21",
    "@types/express-rate-limit": "6.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.10",
    "@types/multer": "1.4.11",
    "@types/node": "20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "8.11.4",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "7.6.0",
    "@typescript-eslint/parser": "7.6.0",
