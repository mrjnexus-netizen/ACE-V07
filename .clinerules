}

interface VibrantPalette {
  vibrant: string;
  muted: string;
  darkVibrant: string;
  darkMuted: string;
  lightVibrant: string;
  lightMuted: string;
}

interface ComposerIdentity {
  id: string | null;
  name: MultiLingual | null;
  tagline: MultiLingual | null;
  biography: MultiLingual | null;
  awards: MultiLingual[] | null;
  studioAddress: MultiLingual | null;
  portrait: MediaAsset | null;
