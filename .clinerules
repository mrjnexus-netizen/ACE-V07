}

type PipelineStatus =
  | 'idle'
  | 'uploading'
  | 'analyzing_audio'
  | 'generating_art'
  | 'generating_narrative'
  | 'applying_filters'
  | 'awaiting_approval'
  | 'publishing'
  | 'complete'
  | 'error';

interface PipelineJob {
  id: string;
