────────────────────────────────────────────────────────────────────────────────
COMPLETE TYPESCRIPT INTERFACE DEFINITIONS
────────────────────────────────────────────────────────────────────────────────

interface MultiLingual {
  en: string;
  es: string;
  fr: string;
  zh: string;
  ja: string;
  ko: string;
}

interface MediaAsset {
  url: string;
  blurHash: string;
  width: number;
  height: number;
  format: 'webp' | 'jpg' | 'png';
  dominantColors: string[];
