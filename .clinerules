}

interface AudioMetadata {
  dominantInstrument: string;
  bpm: number;
  mood: string;
  keySignature: string;
  duration: number;
  title: string | null;
}

type Locale = 'en' | 'es' | 'fr' | 'zh' | 'ja' | 'ko';

type ThemeId = 'onyx' | 'cyber' | 'minimal';

interface ThemeConfig {
  id: ThemeId;
  variables: Record<string, string>;
}

interface ApiResponse<T> {
  success: boolean;
  data: T | null;
  error: string | null;
  code: string | null;
  timestamp: string;
}

